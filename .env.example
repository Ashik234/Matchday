# openfootball — World Cup 2026 (no key, public domain)
VITE_OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json

# BallDontLie FIFA World Cup (free tier: teams + stadiums only)
VITE_BDL_KEY=
VITE_BDL_BASE_URL=https://api.balldontlie.io/fifa/worldcup/v1

# Force fixture data even when keys are present
VITE_USE_FIXTURES=false
