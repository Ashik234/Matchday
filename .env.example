# openfootball — World Cup 2026 (no key, public domain)
VITE_OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
VITE_OPENFOOTBALL_TEAMS_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.teams.json
VITE_OPENFOOTBALL_STADIUMS_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.stadiums.json

# Force fixture data even when keys are present
VITE_USE_FIXTURES=false
